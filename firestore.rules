rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Any signed-in user can read and write all documents.
    // Role-based access control is enforced on the client side (React Router).
    // This is appropriate for an internal business tool used only by known staff.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
