# Firebase Configuration Template
# Copy this file to .env.local and fill in the actual values
# NEVER commit .env.local to version control
# For local development, use .env.local
# For Netlify deployment, add these as environment variables via the Netlify dashboard

# ──────────────────────────────────────────────────────────────────────────────
# FIREBASE CLIENT-SIDE CONFIGURATION (Required)
# ──────────────────────────────────────────────────────────────────────────────

# Firebase API Key (Public - for client-side initialization)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase Authentication Domain
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here

# Firebase Cloud Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here

# Firebase App ID
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Firebase Measurement ID (Google Analytics)
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# ──────────────────────────────────────────────────────────────────────────────
# ADMIN BACKEND CONFIGURATION (Server-side only - DO NOT expose to client)
# ──────────────────────────────────────────────────────────────────────────────

# Admin Backend API URL (for admin operations)
VITE_ADMIN_API_URL=https://your-backend-api.domain.com

# Admin API Token (if required - for backend-to-backend communication)
ADMIN_API_TOKEN=your_admin_api_token_here

# Firebase Admin SDK Service Account (NEVER expose in client code!)
# This should only be used in your backend/server environment
# File: royaltyersapp-firebase-adminsdk-fbsvc-406c1fbf93.json
# Store this securely and never commit to version control

# ──────────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# App Environment (development | staging | production)
VITE_APP_ENV=development

# Enable Debug Mode
VITE_DEBUG_MODE=false

# API Base URL (for any custom backend endpoints)
VITE_API_BASE_URL=http://localhost:3000

